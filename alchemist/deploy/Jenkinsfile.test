pipeline {
    agent {
        label 'test'
    }
    stages {
        stage('Pre') {
            steps {
                script {
                    sh '''
                        git remote update origin --prune
                        git branch -a | grep -e '^  remotes/origin/dev$'
                        echo 'remote dev branch exists'
                        git branch -D dev || echo 'no local dev branch'
                        git branch dev remotes/origin/dev
                    '''
                    sh """
                        git checkout ${BRANCH_NAME}
                        git rebase dev
                        echo 'git rebase dev success'
                        git push origin ${BRANCH_NAME}
                        echo 'git push origin' ${BRANCH_NAME} 'success'
                    """
                }
            }
        }
        stage('Build') {
            steps {
                sh """
                    docker build \
                        --build-arg env=test \
                        -t nextsurfer/alchemist:latest \
                        --build-arg GRPC_SERVER_PORT=${GRPC_SERVER_PORT} \
                        --build-arg GRPC_METRIC_PORT=${GRPC_METRIC_PORT} \
                        --build-arg MYSQL_METRIC_PORT=${MYSQL_METRIC_PORT} \
                        --build-arg HTTP_SERVER_PORT=${HTTP_SERVER_PORT} \
                        -f build/grpc/Dockerfile .
                    docker stop -t 60 -s SIGTERM alchemist && docker rm alchemist || echo 0
                    docker run -d \
                        --name alchemist \
                        --dns ${HOST_IP} \
                        --dns 8.8.8.8 \
                        --restart always \
                        -e 'APP_NAME=${APP_NAME}' \
                        -e 'CONSUL_HTTP_ADDR=${CONSUL_HTTP_ADDR}' \
                        -e 'GRPC_SERVER_HOST=${GRPC_SERVER_HOST}' \
                        -e 'GRPC_SERVER_PORT=${GRPC_SERVER_PORT}' \
                        -e 'GRPC_METRIC_PORT=${GRPC_METRIC_PORT}' \
                        -e 'MYSQL_METRIC_PORT=${MYSQL_METRIC_PORT}' \
                        -e 'HTTP_SERVER_PORT=${HTTP_SERVER_PORT}' \
                        -e 'ALCHEMIST_MANAGER_WEB_PATH=${ALCHEMIST_MANAGER_WEB_PATH}' \
                        -e 'APPLICATION_ENV=${APPLICATION_ENV}' \
                        -e 'ALCHEMIST_REDIS_DNS=${ALCHEMIST_REDIS_DNS}' \
                        -e 'ALCHEMIST_MYSQL_DNS=${ALCHEMIST_MYSQL_DNS}' \
                        -e 'I18N_TOML_PATH=${I18N_TOML_PATH}' \
                        -e 'NOTIFICATION_HANDLE_INTERVAL=${NOTIFICATION_HANDLE_INTERVAL}' \
                        -e 'CONNECTOR_KEY_ID=${CONNECTOR_KEY_ID}' \
                        -p '${GRPC_SERVER_PORT}:${GRPC_SERVER_PORT}' \
                        -p '${GRPC_METRIC_PORT}:${GRPC_METRIC_PORT}' \
                        -p '${MYSQL_METRIC_PORT}:${MYSQL_METRIC_PORT}' \
                        -p '${HTTP_SERVER_PORT}:${HTTP_SERVER_PORT}' \
                        nextsurfer/alchemist:latest
                """
            }
        }
        stage('PushService') {
            steps {
                sh """
                    docker run --rm \
                        -v ./:/app \
                        -w /app \
                        -e 'CONSOLE_HOST=${CONSOLE_HOST}' \
                        -e 'CONSOLE_GRPC_PORT=${CONSOLE_GRPC_PORT}' \
                        golang:1.23 \
                        sh -c \
                        "git config --global url.https://github@github.com.insteadof https://github.com && GOSUMDB=off go mod tidy && go run ./cmd/pushproto"
                """
            }
        }
        stage('Test') {
            steps {
                sh """
                    docker run --rm \
                        -v ./:/app \
                        -w /app \
                        -e 'SLARK_MYSQL_DNS=${SLARK_MYSQL_DNS}' \
                        -e 'ALCHEMIST_MYSQL_DNS=${ALCHEMIST_MYSQL_DNS}' \
                         -e 'ALCHEMIST_REDIS_DNS=${ALCHEMIST_REDIS_DNS}' \
                          -e 'ORACLE_GATEWAY_DNS=${ORACLE_GATEWAY_DNS}' \
                        golang:1.23 \
                        sh -c \
                        "git config --global url.https://github@github.com.insteadof https://github.com && GOSUMDB=off go mod tidy && go test -v ./test/e2e/alchemist ./test/e2e/alchemist_notification ./test/e2e/manage"
                """
            }
        }
    }
    post {
        success {
            sh """
                echo 'e2e testing success'
                git checkout dev
                git rebase ${BRANCH_NAME}
                git push origin dev
            """
        }
        failure {
            sh """
                echo 'feature build or e2e testing fail'
                git checkout dev
                docker build \
                    --build-arg env=test \
                    -t nextsurfer/alchemist:latest \
                    --build-arg GRPC_SERVER_PORT=${GRPC_SERVER_PORT} \
                    --build-arg GRPC_METRIC_PORT=${GRPC_METRIC_PORT} \
                    --build-arg MYSQL_METRIC_PORT=${MYSQL_METRIC_PORT} \
                    --build-arg HTTP_SERVER_PORT=${HTTP_SERVER_PORT} \
                    -f build/grpc/Dockerfile .
                docker stop -t 60 -s SIGTERM alchemist && docker rm alchemist || echo 0
                docker run -d \
                    --name alchemist \
                    --dns ${HOST_IP} \
                    --dns 8.8.8.8 \
                    --restart always \
                    -e 'APP_NAME=${APP_NAME}' \
                    -e 'CONSUL_HTTP_ADDR=${CONSUL_HTTP_ADDR}' \
                    -e 'GRPC_SERVER_HOST=${GRPC_SERVER_HOST}' \
                    -e 'GRPC_SERVER_PORT=${GRPC_SERVER_PORT}' \
                    -e 'GRPC_METRIC_PORT=${GRPC_METRIC_PORT}' \
                    -e 'MYSQL_METRIC_PORT=${MYSQL_METRIC_PORT}' \
                    -e 'HTTP_SERVER_PORT=${HTTP_SERVER_PORT}' \
                    -e 'ALCHEMIST_MANAGER_WEB_PATH=${ALCHEMIST_MANAGER_WEB_PATH}' \
                    -e 'APPLICATION_ENV=${APPLICATION_ENV}' \
                    -e 'ALCHEMIST_REDIS_DNS=${ALCHEMIST_REDIS_DNS}' \
                    -e 'ALCHEMIST_MYSQL_DNS=${ALCHEMIST_MYSQL_DNS}' \
                    -e 'I18N_TOML_PATH=${I18N_TOML_PATH}' \
                    -e 'NOTIFICATION_HANDLE_INTERVAL=${NOTIFICATION_HANDLE_INTERVAL}' \
                    -e 'CONNECTOR_KEY_ID=${CONNECTOR_KEY_ID}' \
                    -p '${GRPC_SERVER_PORT}:${GRPC_SERVER_PORT}' \
                    -p '${GRPC_METRIC_PORT}:${GRPC_METRIC_PORT}' \
                    -p '${MYSQL_METRIC_PORT}:${MYSQL_METRIC_PORT}' \
                    -p '${HTTP_SERVER_PORT}:${HTTP_SERVER_PORT}' \
                    nextsurfer/alchemist:latest
            """
        }
        cleanup {
            sh """
                docker system prune -f
            """
            cleanWs()
        }
    }
}