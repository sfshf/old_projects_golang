pipeline {
    agent {
        label 'hongkong-test'
    }
    stages {
        stage('Pre') {
            steps {
                script {
                    sh '''
                        git remote update origin --prune
                        git branch -a | grep -e '^  remotes/origin/dev$'
                        echo 'remote dev branch exists'
                        git branch -D dev || echo 'no local dev branch'
                        git branch dev remotes/origin/dev
                    '''
                    sh """
                        git checkout ${BRANCH_NAME}
                        git rebase dev
                        echo 'git rebase dev success'
                        git push origin ${BRANCH_NAME}
                        echo 'git push origin' ${BRANCH_NAME} 'success'
                    """
                }
            }
        }
        stage('Build') {
            steps {
                sh """
                    docker build \
                        --build-arg env=test \
                        --build-arg GRPC_SERVER_PORT=${GRPC_SERVER_PORT} \
                        --build-arg GRPC_METRIC_PORT=${GRPC_METRIC_PORT} \
                        -t nextsurfer/doom-go:latest \
                        -f build/doom/Dockerfile .
                    docker stop -t 60 -s SIGTERM doom-go && docker rm doom-go || echo 0
                    docker run -itd \
                        --name doom-go \
                        --dns ${HOST_IP} \
                        --dns 8.8.8.8 \
                        --restart always \
                        -e 'APP_NAME=${APP_NAME}' \
                        -e 'CONSUL_HTTP_ADDR=${CONSUL_HTTP_ADDR}' \
                        -e 'GRPC_SERVER_HOST=${GRPC_SERVER_HOST}' \
                        -e 'GRPC_SERVER_PORT=${GRPC_SERVER_PORT}' \
                        -e 'GRPC_METRIC_PORT=${GRPC_METRIC_PORT}' \
                        -e 'APPLICATION_ENV=${APPLICATION_ENV}' \
                        -e 'DOOM_REDIS_DNS=${DOOM_REDIS_DNS}' \
                        -e 'CONNECTOR_API_KEY=${CONNECTOR_API_KEY}' \
                        -e 'CONNECTOR_KEY_ID=${CONNECTOR_KEY_ID}' \
                        -e 'UPDATE_CONNECTOR_KEY=${UPDATE_CONNECTOR_KEY}' \
                        -e 'I18N_TOML_PATH=${I18N_TOML_PATH}' \
                        -e 'CRYPTOCURRENCY_CHAIN_CONFIG_PATH=${CRYPTOCURRENCY_CHAIN_CONFIG_PATH}' \
                        -e 'DOOM_MONGODB_URI=${DOOM_MONGODB_URI}' \
                        -p '${GRPC_SERVER_PORT}:${GRPC_SERVER_PORT}' \
                        -p '${GRPC_METRIC_PORT}:${GRPC_METRIC_PORT}' \
                        nextsurfer/doom-go:latest
                """
            }
        }
        stage('PushService') {
            steps {
                sh """
                    docker run --rm \
                        -v ./:/test \
                        -w /test \
                        -e 'CONSOLE_HOST=${CONSOLE_HOST}' \
                        -e 'CONSOLE_GRPC_PORT=${CONSOLE_GRPC_PORT}' \
                        golang:1.23 \
                        sh -c \
                        "git config --global url.https://github@github.com.insteadof https://github.com && GOSUMDB=off go mod tidy && go run ./cmd/pushproto"
                """
            }
        }
        stage('Push2tester') {
            steps {
                sh 'docker run --rm \
                        -v ./:/test \
                        -w /test \
                        golang:1.23 \
                        sh -c \
                        "git config --global url.https://github@github.com.insteadof https://github.com && GOSUMDB=off go mod tidy && go run ./cmd/push2tester"'
            }
        }
        stage('Test') {
            steps {
                sh """
                    docker run --rm \
                        -v ./:/test \
                        -w /test \
                        -e 'SLARK_MYSQL_DNS=${SLARK_MYSQL_DNS}' \
                        -e 'CONNECTOR_API_KEY=${CONNECTOR_API_KEY}' \
                        -e 'CONNECTOR_KEY_ID=${CONNECTOR_KEY_ID}' \
                        golang:1.23 \
                        sh -c \
                        "git config --global url.https://github@github.com.insteadof https://github.com && GOSUMDB=off go mod tidy && go test --ldflags '-extldflags "-Wl,--allow-multiple-definition"' -v -timeout 0 ./test/e2e/doom-go"

                """
            }
        }
    }
    post {
        success {
            sh """
                echo 'e2e testing success'
                git checkout dev
                git rebase ${BRANCH_NAME}
                git push origin dev
            """
        }
        failure {
            sh """
                echo 'feature build or e2e testing fail'
                git checkout dev
                docker build \
                    --build-arg env=test \
                    --build-arg GRPC_SERVER_PORT=${GRPC_SERVER_PORT} \
                    --build-arg GRPC_METRIC_PORT=${GRPC_METRIC_PORT} \
                    -t nextsurfer/doom-go:latest \
                    -f build/doom/Dockerfile .
                docker stop -t 60 -s SIGTERM doom-go && docker rm doom-go || echo 0
                docker run -itd \
                    --name doom-go \
                    --dns ${HOST_IP} \
                    --dns 8.8.8.8 \
                    --restart always \
                    -e 'APP_NAME=${APP_NAME}' \
                    -e 'CONSUL_HTTP_ADDR=${CONSUL_HTTP_ADDR}' \
                    -e 'GRPC_SERVER_HOST=${GRPC_SERVER_HOST}' \
                    -e 'GRPC_SERVER_PORT=${GRPC_SERVER_PORT}' \
                    -e 'GRPC_METRIC_PORT=${GRPC_METRIC_PORT}' \
                    -e 'APPLICATION_ENV=${APPLICATION_ENV}' \
                    -e 'DOOM_REDIS_DNS=${DOOM_REDIS_DNS}' \
                    -e 'CONNECTOR_API_KEY=${CONNECTOR_API_KEY}' \
                    -e 'CONNECTOR_KEY_ID=${CONNECTOR_KEY_ID}' \
                    -e 'UPDATE_CONNECTOR_KEY=${UPDATE_CONNECTOR_KEY}' \
                    -e 'I18N_TOML_PATH=${I18N_TOML_PATH}' \
                    -e 'CRYPTOCURRENCY_CHAIN_CONFIG_PATH=${CRYPTOCURRENCY_CHAIN_CONFIG_PATH}' \
                    -e 'DOOM_MONGODB_URI=${DOOM_MONGODB_URI}' \
                    -p '${GRPC_SERVER_PORT}:${GRPC_SERVER_PORT}' \
                    -p '${GRPC_METRIC_PORT}:${GRPC_METRIC_PORT}' \
                    nextsurfer/doom-go:latest
            """ 
        }
        cleanup {
            sh """
                docker system prune -f
            """
            cleanWs()
        }
    }
}